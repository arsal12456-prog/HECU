<Window x:Class="HECUVoiceLab.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="HECU Voice Lab" Width="980" Height="720" Background="#1b1d20" Foreground="#eee">
 <Window.Resources><Style TargetType="TextBlock"><Setter Property="Margin" Value="4"/></Style><Style TargetType="Slider"><Setter Property="Margin" Value="4"/></Style><Style TargetType="Button"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="10,6"/></Style></Window.Resources>
 <DockPanel Margin="12"><StackPanel DockPanel.Dock="Top"><TextBlock Text="HECU Voice Lab" FontSize="28" FontWeight="Bold"/><TextBlock Text="Local real-time DSP voice changer: physical mic → HECU processing → virtual cable playback."/><WrapPanel><Button x:Name="StartStopButton" Content="START" FontSize="22" Click="StartStop_Click"/><Button Content="Refresh Devices" Click="Refresh_Click"/><CheckBox x:Name="BypassBox" Content="Bypass" Margin="10" Checked="ControlChanged" Unchecked="ControlChanged"/><TextBlock x:Name="ClipText" Text="Clip: OK" Foreground="LightGreen"/><TextBlock x:Name="StatusText" Text="Stopped"/></WrapPanel><ProgressBar x:Name="InputMeter" Height="12" Maximum="1"/><ProgressBar x:Name="OutputMeter" Height="12" Maximum="1"/></StackPanel>
 <TabControl x:Name="Tabs">
  <TabItem Header="Routing"><StackPanel Margin="10"><TextBlock Text="Input device (physical microphone)"/><ComboBox x:Name="InputCombo" DisplayMemberPath="Name"/><TextBlock Text="Output device (choose CABLE Input (VB-Audio Virtual Cable))"/><ComboBox x:Name="OutputCombo" DisplayMemberPath="Name"/><TextBlock x:Name="RoutingText" TextWrapping="Wrap"/><TextBlock Text="Discord/OBS/game should use CABLE Output (VB-Audio Virtual Cable) as microphone."/></StackPanel></TabItem>
  <TabItem Header="Presets"><StackPanel Margin="10"><ComboBox x:Name="PresetCombo" DisplayMemberPath="Name" SelectionChanged="PresetCombo_SelectionChanged"/><Button Content="Reset to HECU Reference" Click="Reset_Click"/><TextBlock Text="Presets update actual DSP modules: gate, EQ, crunch, compressor, saturation, chop, limiter."/></StackPanel></TabItem>
  <TabItem Header="Radio Tone"><ScrollViewer><StackPanel x:Name="RadioPanel" Margin="10"/></ScrollViewer></TabItem>
  <TabItem Header="GoldSrc Crunch"><ScrollViewer><StackPanel x:Name="CrunchPanel" Margin="10"/></ScrollViewer></TabItem>
  <TabItem Header="Compression/Grit"><ScrollViewer><StackPanel x:Name="CompPanel" Margin="10"/></ScrollViewer></TabItem>
  <TabItem Header="Tactical Chop"><ScrollViewer><StackPanel x:Name="ChopPanel" Margin="10"/></ScrollViewer></TabItem>
  <TabItem Header="Reference Match"><StackPanel Margin="10"><TextBlock Text="Embedded Target Profile" FontWeight="Bold"/><TextBlock x:Name="TargetText" TextWrapping="Wrap"/><WrapPanel><Button Content="Analyze Embedded Target" Click="AnalyzeEmbedded_Click"/><Button Content="Load Local MP3/WAV Reference" Click="LoadReference_Click"/></WrapPanel><TextBox x:Name="AnalysisText" Height="280" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/></StackPanel></TabItem>
  <TabItem Header="Help"><ScrollViewer><TextBlock Margin="10" TextWrapping="Wrap" Text="Route: Physical microphone → HECU Voice Lab input. HECU output → CABLE Input playback device. Discord/OBS/game mic → CABLE Output recording device. No Valve/Half-Life audio is included; this is local DSP only, no cloud, login, telemetry, cloning, or proprietary pipeline claim."/></ScrollViewer></TabItem>
 </TabControl></DockPanel>
</Window>
